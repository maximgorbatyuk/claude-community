---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="page">
		<button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<circle cx="12" cy="12" r="5"></circle>
				<line x1="12" y1="1" x2="12" y2="3"></line>
				<line x1="12" y1="21" x2="12" y2="23"></line>
				<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
				<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
				<line x1="1" y1="12" x2="3" y2="12"></line>
				<line x1="21" y1="12" x2="23" y2="12"></line>
				<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
				<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
			</svg>
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
			</svg>
		</button>

		<main class="hero">
			<div class="terminal-status" aria-hidden="true">
				<span class="status-symbol" id="status-symbol"></span>
				<span class="status-text" id="status-text"></span>
			</div>

			<h1 class="title">
				Claude Community
				<span class="title-accent">Kazakhstan</span>
			</h1>

			<p class="subtitle">Coming Soon</p>

			<p class="description">
				A community for AI enthusiasts, developers, and researchers
				building with Claude in Kazakhstan.
			</p>

			<div class="links">
				<a href="https://t.me/claude_community_kz" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
					Join Telegram
				</a>
				<a href="https://github.com/anthropics/claude-code" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
					Claude Code
				</a>
			</div>
		</main>

		<footer class="footer">
			<p>&copy; 2025 Claude Community Kazakhstan</p>
		</footer>
	</div>
</Layout>

<style>
	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
	}

	/* Background grid pattern */
	.page::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(var(--border-secondary) 1px, transparent 1px),
			linear-gradient(90deg, var(--border-secondary) 1px, transparent 1px);
		background-size: 60px 60px;
		opacity: 0.3;
		pointer-events: none;
	}

	/* Radial glow behind hero */
	.page::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, rgba(217, 119, 87, 0.08) 0%, transparent 70%);
		pointer-events: none;
	}

	/* Theme toggle */
	.theme-toggle {
		position: absolute;
		top: var(--space-5);
		right: var(--space-5);
		background: var(--bg-tertiary);
		border: 1px solid var(--border-secondary);
		border-radius: var(--radius-xl);
		color: var(--fg-secondary);
		cursor: pointer;
		padding: var(--space-2);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: color var(--transition-default), border-color var(--transition-default), background var(--transition-default);
		z-index: 10;
	}

	.theme-toggle:hover {
		color: var(--fg-primary);
		border-color: var(--border-primary);
	}

	[data-theme='dark'] .icon-sun { display: block; }
	[data-theme='dark'] .icon-moon { display: none; }
	[data-theme='light'] .icon-sun { display: none; }
	[data-theme='light'] .icon-moon { display: block; }

	/* Hero */
	.hero {
		position: relative;
		z-index: 1;
		text-align: center;
		padding: var(--space-6);
		max-width: 40rem;
	}

	/* Terminal status animation */
	.terminal-status {
		font-family: var(--font-mono);
		font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
		color: var(--fg-tertiary);
		margin-bottom: var(--space-6);
		letter-spacing: 0.05em;
		min-height: 1.5em;
	}

	.status-symbol {
		margin-right: var(--space-2);
	}

	/* Title */
	.title {
		font-family: var(--font-serif);
		font-size: clamp(2.5rem, 2rem + 2vw, 4rem);
		font-weight: 700;
		line-height: var(--line-height-heading);
		color: var(--fg-primary);
		margin-bottom: var(--space-4);
	}

	.title-accent {
		display: block;
		color: var(--accent);
	}

	/* Subtitle */
	.subtitle {
		font-family: var(--font-mono);
		font-size: clamp(1.125rem, 1rem + 0.5vw, 1.5rem);
		color: var(--fg-secondary);
		margin-bottom: var(--space-5);
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	/* Description */
	.description {
		font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
		color: var(--fg-secondary);
		line-height: var(--line-height-body);
		margin-bottom: var(--space-7);
		max-width: 32rem;
		margin-left: auto;
		margin-right: auto;
	}

	/* Buttons */
	.links {
		display: flex;
		gap: var(--space-4);
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		padding: 10px 20px;
		border-radius: var(--radius-md);
		font-weight: 500;
		font-size: 0.9375rem;
		text-decoration: none;
		transition: background var(--transition-default), color var(--transition-default), border-color var(--transition-default);
	}

	.btn-primary {
		background: var(--accent);
		color: #ffffff;
		border: 1px solid transparent;
	}

	.btn-primary:hover {
		background: var(--accent-hover);
		color: #ffffff;
	}

	.btn-secondary {
		background: transparent;
		color: var(--fg-primary);
		border: 1px solid var(--border-primary);
	}

	.btn-secondary:hover {
		border-color: var(--fg-tertiary);
		color: var(--fg-primary);
	}

	/* Footer */
	.footer {
		position: absolute;
		bottom: var(--space-5);
		z-index: 1;
	}

	.footer p {
		font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
		color: var(--fg-tertiary);
	}

	@media (max-width: 480px) {
		.hero {
			padding: var(--space-5);
		}

		.links {
			flex-direction: column;
			align-items: center;
		}

		.btn {
			width: 100%;
			justify-content: center;
			max-width: 16rem;
		}
	}
</style>

<script>
	// Theme toggle
	const toggle = document.getElementById('theme-toggle');
	if (toggle) {
		toggle.addEventListener('click', () => {
			const current = document.documentElement.getAttribute('data-theme');
			const next = current === 'dark' ? 'light' : 'dark';
			document.documentElement.setAttribute('data-theme', next);
			localStorage.setItem('theme', next);
		});
	}

	// Terminal status animation
	const symbols = ['◈', '◓', '✽', '◐', '◑', '◒', '●', '◯', '◇', '◆', '▲', '▼'];
	const messages = [
		'Initializing community...',
		'Building connections...',
		'Compiling ideas...',
		'Loading resources...',
		'Preparing launch...',
	];

	const symbolEl = document.getElementById('status-symbol');
	const textEl = document.getElementById('status-text');
	let symbolIndex = 0;
	let messageIndex = 0;

	const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (!prefersReduced && symbolEl && textEl) {
		textEl.textContent = messages[0];
		symbolEl.textContent = symbols[0];

		setInterval(() => {
			symbolIndex = (symbolIndex + 1) % symbols.length;
			symbolEl.textContent = symbols[symbolIndex];
		}, 800);

		setInterval(() => {
			messageIndex = (messageIndex + 1) % messages.length;
			textEl.textContent = messages[messageIndex];
		}, 3000);
	} else if (symbolEl && textEl) {
		symbolEl.textContent = '◈';
		textEl.textContent = 'Preparing launch...';
	}
</script>
