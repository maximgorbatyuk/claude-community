---
import { type Locale, t, getLocalePath } from '../i18n';
import projects from '../data/projects.json';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const terminalMessages = JSON.stringify([
  t(lang, 'terminal.msg1'),
  t(lang, 'terminal.msg2'),
  t(lang, 'terminal.msg3'),
  t(lang, 'terminal.msg4'),
  t(lang, 'terminal.msg5'),
]);

const asciiLogo = `  ___  __                __
 / ___ | |               | |
| |    | | __ _ _   _  __| | ___
| |    | |/ _\` | | | |/ _\` |/ _ \\
| |___ | | (_| | |_| | (_| |  __/
 \\____ |_|\\__,_|\\__,_|\\__,_|\\___|`;
---

<div class="page">
  <main class="hero">
    <div class="terminal-status" aria-hidden="true" data-messages={terminalMessages}>
      <span class="status-symbol" id="status-symbol"></span>
      <span class="status-text" id="status-text"></span>
    </div>

    <h1 class="title">
      {t(lang, 'hero.title')}
      <span class="title-accent">{t(lang, 'hero.accent')}</span>
    </h1>

    <p class="description">{t(lang, 'hero.description')}</p>

    <p class="chat-invite">{t(lang, 'hero.chatInvite')}</p>

    <div class="links">
      <a href="https://t.me/teamleads_kz" class="btn" target="_blank" rel="noopener noreferrer">@teamleads_kz</a>
      <a href="https://t.me/frontendkz" class="btn" target="_blank" rel="noopener noreferrer">@frontendkz</a>
      <a href="https://t.me/cursor_kz" class="btn" target="_blank" rel="noopener noreferrer">@cursor_kz</a>
    </div>

    <p class="chat-note">{t(lang, 'hero.chatNote')}</p>
  </main>

  <section class="builtwithclaude-section">
    <h2 class="section-title">#builtwithclaude</h2>
    <p class="project-count">{projects.length} {t(lang, 'bwc.projectsCount')}</p>
    <p class="section-description">{t(lang, 'bwc.description')}</p>
    <a href={getLocalePath(lang, '/projects/')} class="btn btn-primary">
      {t(lang, 'bwc.link')}
    </a>
  </section>

  <section id="about-us" class="about-section">
    <h2 class="section-title">{t(lang, 'about.heading')}</h2>
    <p class="section-description">{t(lang, 'about.description')}</p>
  </section>

  <footer class="footer">
    <div class="footer-grid">
      <div class="footer-col footer-brand">
        <pre class="footer-ascii" aria-hidden="true" set:html={asciiLogo} />
        <p class="footer-tagline">Community Kazakhstan</p>
        <p class="footer-copyright">{t(lang, 'footer.copyright')}</p>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">{t(lang, 'footer.nav')}</h3>
        <ul class="footer-links">
          <li><a href={getLocalePath(lang, '/')}>{t(lang, 'nav.main')}</a></li>
          <li><a href={getLocalePath(lang, '/projects/')}>#builtwithclaude</a></li>
          <li><a href={getLocalePath(lang, '/about/')}>{t(lang, 'nav.about')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">{t(lang, 'footer.friends')}</h3>
        <ul class="footer-links">
          <li><a href="https://t.me/teamleads_kz" target="_blank" rel="noopener noreferrer">@teamleads_kz</a></li>
          <li><a href="https://t.me/frontendkz" target="_blank" rel="noopener noreferrer">@frontendkz</a></li>
          <li><a href="https://t.me/cursor_kz" target="_blank" rel="noopener noreferrer">@cursor_kz</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">GitHub</h3>
        <ul class="footer-links">
          <li><a href="https://github.com/maximgorbatyuk/claude-community" target="_blank" rel="noopener noreferrer">{t(lang, 'footer.repository')}</a></li>
          <li><a href="https://github.com/maximgorbatyuk/claude-community/issues/new?template=suggest-project.yml" target="_blank" rel="noopener noreferrer">{t(lang, 'footer.suggestProject')}</a></li>
          <li><a href="https://github.com/maximgorbatyuk/claude-community/issues" target="_blank" rel="noopener noreferrer">Issues</a></li>
        </ul>
      </div>
    </div>
  </footer>
</div>

<style>
  .page {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-8) 0 0;
    position: relative;
    overflow: hidden;
  }

  /* Background grid pattern */
  .page::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border-secondary) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-secondary) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.3;
    pointer-events: none;
  }

  /* Radial glow behind hero */
  .page::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(217, 119, 87, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--space-6);
    max-width: 40rem;
  }

  .terminal-status {
    font-family: var(--font-mono);
    font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
    color: var(--fg-tertiary);
    margin-bottom: var(--space-6);
    letter-spacing: 0.05em;
    min-height: 1.5em;
  }

  .status-symbol {
    margin-right: var(--space-2);
  }

  .title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 2rem + 2vw, 4rem);
    font-weight: 700;
    line-height: var(--line-height-heading);
    color: var(--fg-primary);
    margin-bottom: var(--space-4);
  }

  .title-accent {
    display: block;
    color: var(--accent);
  }

  .description {
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
    margin-bottom: var(--space-7);
    max-width: 32rem;
    margin-left: auto;
    margin-right: auto;
  }

  .links {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .chat-invite {
    font-size: clamp(0.875rem, 0.85rem + 0.15vw, 1rem);
    color: var(--fg-secondary);
    text-align: center;
    margin-bottom: var(--space-5);
  }

  .chat-note {
    font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
    color: var(--fg-tertiary);
    text-align: center;
    margin-top: var(--space-5);
    max-width: 32rem;
    margin-left: auto;
    margin-right: auto;
    line-height: var(--line-height-body);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    background: transparent;
    color: var(--fg-primary);
    border: 1px solid var(--border-primary);
    transition: background var(--transition-default), color var(--transition-default), border-color var(--transition-default);
  }

  .btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    border: 1px solid transparent;
    transition: background var(--transition-default);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    color: #fff;
    border-color: transparent;
  }

  .builtwithclaude-section {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--space-6);
    max-width: 40rem;
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: clamp(1.25rem, 1.1rem + 0.65vw, 1.75rem);
    font-weight: 700;
    color: var(--accent);
    margin-bottom: var(--space-3);
  }

  .project-count {
    font-size: clamp(1.5rem, 1.3rem + 0.85vw, 2.25rem);
    font-weight: 700;
    color: var(--fg-primary);
    margin-bottom: var(--space-3);
  }

  .section-description {
    font-size: clamp(0.875rem, 0.85rem + 0.15vw, 1rem);
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
    max-width: 28rem;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: var(--space-5);
  }

  .about-section {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--space-6);
    max-width: 40rem;
  }

  .footer {
    width: 100%;
    margin-top: auto;
    z-index: 1;
    background: #131313;
    border-top: 1px solid #525252;
    padding: var(--space-7) var(--space-6);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-6);
    max-width: 64rem;
    margin: 0 auto;
  }

  .footer-ascii {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    line-height: 1.2;
    color: var(--accent);
    white-space: pre;
    overflow: hidden;
    margin: 0;
  }

  .footer-tagline {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 1.1rem + 0.65vw, 1.75rem);
    color: #f5f5f5;
    margin-top: var(--space-2);
  }

  .footer-copyright {
    font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
    color: #737373;
    margin-top: var(--space-2);
  }

  .footer-heading {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: #f5f5f5;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-links a {
    font-size: 0.875rem;
    color: #9a9a9a;
    text-decoration: none;
    transition: color var(--transition-default);
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .hero {
      padding: var(--space-5);
    }

    .links {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      justify-content: center;
      max-width: 16rem;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .footer-ascii {
      display: none;
    }
  }
</style>

<script>
  const symbols = ['◈', '◓', '✽', '◐', '◑', '◒', '●', '◯', '◇', '◆', '▲', '▼'];
  const terminalEl = document.querySelector('.terminal-status');
  const symbolEl = document.getElementById('status-symbol');
  const textEl = document.getElementById('status-text');

  const messages: string[] = terminalEl
    ? JSON.parse(terminalEl.getAttribute('data-messages') || '[]')
    : [];

  let symbolIndex = 0;
  let messageIndex = 0;

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced && symbolEl && textEl && messages.length > 0) {
    textEl.textContent = messages[0];
    symbolEl.textContent = symbols[0];

    setInterval(() => {
      symbolIndex = (symbolIndex + 1) % symbols.length;
      symbolEl.textContent = symbols[symbolIndex];
    }, 800);

    setInterval(() => {
      messageIndex = (messageIndex + 1) % messages.length;
      textEl.textContent = messages[messageIndex];
    }, 3000);
  } else if (symbolEl && textEl && messages.length > 0) {
    symbolEl.textContent = '◈';
    textEl.textContent = messages[messages.length - 1];
  }
</script>
