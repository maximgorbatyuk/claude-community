---
import { type Locale, t, getLocalePath } from '../i18n';
import projects from '../data/projects.json';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const terminalMessages = JSON.stringify([
  t(lang, 'terminal.msg1'),
  t(lang, 'terminal.msg2'),
  t(lang, 'terminal.msg3'),
  t(lang, 'terminal.msg4'),
  t(lang, 'terminal.msg5'),
]);

---

<div class="page">
  <main class="hero">
    <div class="terminal-status" aria-hidden="true" data-messages={terminalMessages}>
      <span class="status-symbol" id="status-symbol"></span>
      <span class="status-text" id="status-text"></span>
    </div>

    <h1 class="title">
      {t(lang, 'hero.title')}
      <span class="title-accent">{t(lang, 'hero.accent')}</span>
    </h1>

    <p class="description">{t(lang, 'hero.description')}</p>

    <p class="chat-invite">{t(lang, 'hero.chatInvite')}</p>

    <div class="links">
      <a href="https://t.me/teamleads_kz" class="btn" data-telegram="teamleads_kz" target="_blank" rel="noopener noreferrer">@teamleads_kz</a>
      <a href="https://t.me/frontendkz" class="btn" data-telegram="frontendkz" target="_blank" rel="noopener noreferrer">@frontendkz</a>
      <a href="https://t.me/almaty_nullptr_party" class="btn" data-telegram="almaty_nullptr_party" target="_blank" rel="noopener noreferrer">@almaty_nullptr_party</a>
    </div>

    <p class="chat-note">{t(lang, 'hero.chatNote')}</p>
  </main>

  <section class="builtwithclaude-section">
    <h2 class="section-title">#builtwithclaude</h2>
    <p class="project-count">{projects.length} {t(lang, 'bwc.projectsCount')}</p>
    <p class="section-description">{t(lang, 'bwc.description')}</p>
    <a href={getLocalePath(lang, '/projects/')} class="btn btn-primary" data-ga-event="projects_click">
      {t(lang, 'bwc.link')}
    </a>
  </section>

  <section id="about-us" class="about-section">
    <h2 class="section-title">{t(lang, 'about.heading')}</h2>
    <p class="section-description">{t(lang, 'about.description')}</p>
  </section>


</div>

<style>
  .page {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-8) 0 0;
    position: relative;
    overflow: hidden;
  }

  /* Background grid pattern */
  .page::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border-secondary) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-secondary) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.3;
    pointer-events: none;
  }

  /* Radial glow behind hero */
  .page::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(217, 119, 87, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--space-6);
    max-width: 40rem;
  }

  .terminal-status {
    font-family: var(--font-mono);
    font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
    color: var(--fg-tertiary);
    margin-bottom: var(--space-6);
    letter-spacing: 0.05em;
    min-height: 1.5em;
  }

  .status-symbol {
    margin-right: var(--space-2);
  }

  .title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 2rem + 2vw, 4rem);
    font-weight: 700;
    line-height: var(--line-height-heading);
    color: var(--fg-primary);
    margin-bottom: var(--space-4);
  }

  .title-accent {
    display: block;
    color: var(--accent);
  }

  .description {
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
    margin-bottom: var(--space-7);
    max-width: 32rem;
    margin-left: auto;
    margin-right: auto;
  }

  .links {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .chat-invite {
    font-size: clamp(0.875rem, 0.85rem + 0.15vw, 1rem);
    color: var(--fg-secondary);
    text-align: center;
    margin-bottom: var(--space-5);
  }

  .chat-note {
    font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
    color: var(--fg-tertiary);
    text-align: center;
    margin-top: var(--space-5);
    max-width: 32rem;
    margin-left: auto;
    margin-right: auto;
    line-height: var(--line-height-body);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    background: transparent;
    color: var(--fg-primary);
    border: 1px solid var(--border-primary);
    transition: background var(--transition-default), color var(--transition-default), border-color var(--transition-default);
  }

  .btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    border: 1px solid transparent;
    transition: background var(--transition-default);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    color: #fff;
    border-color: transparent;
  }

  .builtwithclaude-section {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--space-6);
    max-width: 40rem;
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: clamp(1.25rem, 1.1rem + 0.65vw, 1.75rem);
    font-weight: 700;
    color: var(--accent);
    margin-bottom: var(--space-3);
  }

  .project-count {
    font-size: clamp(1.5rem, 1.3rem + 0.85vw, 2.25rem);
    font-weight: 700;
    color: var(--fg-primary);
    margin-bottom: var(--space-3);
  }

  .section-description {
    font-size: clamp(0.875rem, 0.85rem + 0.15vw, 1rem);
    color: var(--fg-secondary);
    line-height: var(--line-height-body);
    max-width: 28rem;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: var(--space-5);
  }

  .about-section {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--space-6);
    max-width: 40rem;
  }




  @media (max-width: 480px) {
    .hero {
      padding: var(--space-5);
    }

    .links {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      justify-content: center;
      max-width: 16rem;
    }

  }
</style>

<script>
  const symbols = ['◈', '◓', '✽', '◐', '◑', '◒', '●', '◯', '◇', '◆', '▲', '▼'];
  const terminalEl = document.querySelector('.terminal-status');
  const symbolEl = document.getElementById('status-symbol');
  const textEl = document.getElementById('status-text');

  const messages: string[] = terminalEl
    ? JSON.parse(terminalEl.getAttribute('data-messages') || '[]')
    : [];

  let symbolIndex = 0;
  let messageIndex = 0;

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced && symbolEl && textEl && messages.length > 0) {
    textEl.textContent = messages[0];
    symbolEl.textContent = symbols[0];

    setInterval(() => {
      symbolIndex = (symbolIndex + 1) % symbols.length;
      symbolEl.textContent = symbols[symbolIndex];
    }, 800);

    setInterval(() => {
      messageIndex = (messageIndex + 1) % messages.length;
      textEl.textContent = messages[messageIndex];
    }, 3000);
  } else if (symbolEl && textEl && messages.length > 0) {
    symbolEl.textContent = '◈';
    textEl.textContent = messages[messages.length - 1];
  }

  const ga = (window as any).gtag;
  if (typeof ga === 'function') {
    document.querySelectorAll<HTMLAnchorElement>('a[data-telegram]').forEach(link => {
      link.addEventListener('click', () => {
        ga('event', 'telegram_click', {
          event_category: 'outbound',
          event_label: link.getAttribute('data-telegram'),
        });
      });
    });

    document.querySelectorAll<HTMLAnchorElement>('a[data-ga-event]').forEach(link => {
      link.addEventListener('click', () => {
        ga('event', link.getAttribute('data-ga-event'), {
          event_category: 'navigation',
        });
      });
    });
  }
</script>
